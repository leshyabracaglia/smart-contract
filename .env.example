# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to git.

# Your Alchemy HTTPS endpoint for Sepolia
# Get it from: https://dashboard.alchemy.com -> Your App -> API Key
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# The private key of the wallet that will deploy the contract
# Export from MetaMask: Account Details -> Show Private Key
# Include the leading 0x
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
